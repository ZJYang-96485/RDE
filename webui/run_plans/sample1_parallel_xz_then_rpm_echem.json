{
  "schema_version": 2,
  "run_name": "sample1_parallel_xz_then_rpm_echem",
  "display_name": "Sample 1 \u2014 Parallel X/Z Then RPM + EChem",
  "description": "Time-saving example with explicit simultaneous X/Z movement, followed by concurrent RPM + EChem.",
  "repetitions": 1,
  "groups": [
    {
      "group_id": "sample_001",
      "label": "Sample 1",
      "enabled": true,
      "steps": [
        {
          "name": "Move X and Z Together",
          "action": "move_xz_parallel",
          "enabled": true,
          "x_steps": 1000,
          "z_steps": 1000
        },
        {
          "name": "Run 1600 RPM with OCP",
          "action": "rpm_echem",
          "enabled": true,
          "rpm": 1600,
          "protocol": "ocp_only",
          "rpm_settle_s": 2,
          "stop_rpm_after": true
        },
        {
          "name": "Return X and Z Together",
          "action": "move_xz_parallel",
          "enabled": true,
          "x_steps": -1000,
          "z_steps": -1000
        }
      ]
    }
  ]
}
